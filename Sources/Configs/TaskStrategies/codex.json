{
  "strategyID": "codex",
  "displayName": "Codex",
  "priority": 260,
  "supports": {
    "titleContains": ["codex"],
    "titleRegex": [
      "(?i)\\bgpt-[0-9.]+-codex\\b"
    ],
    "tailContains": [
      "openai codex",
      "gpt-5-codex",
      "gpt-5.3-codex",
      "gpt-5.4-codex",
      "exec_command",
      "apply_patch",
      "update_plan",
      "• ran ",
      "• explored",
      "• edited",
      "• added",
      "• working"
    ],
    "tailRegex": [
      "(?im)^\\s*•\\s*(ran|explored|edited|added|updated)\\b",
      "(?im)^\\s*─\\s*worked\\s+for\\b",
      "(?im)^\\s*gpt-[0-9.]+-codex\\s+"
    ]
  },
  "lifecycleRules": {
    "error": {
      "titleContains": [],
      "titleRegex": [],
      "tailContains": [
        "error:",
        "traceback",
        "build failed",
        "test failed",
        "xctassert",
        "permission denied",
        "sandbox denied",
        "network access is restricted",
        "rate limit exceeded",
        "rate limits exceeded",
        "rate limit reached",
        "rate limited",
        "too many requests",
        "429",
        "exited with code",
        "invalid_request_error",
        "auth_error"
      ],
      "tailRegex": [
        "(?im)^\\s*error:\\s+",
        "(?im)^\\s*test case .* failed",
        "(?im)^\\s*xctassert[a-z]*\\(",
        "(?i)\\brate[_ -]?limit(?:ed|s)?\\s*(?:exceeded|reached|exhausted|hit(?:ted)?|error)\\b",
        "(?i)\\brate[_ -]?limited\\b",
        "(?i)\\bhit\\s+(?:your|the\\s+)?rate[_ -]?limit",
        "(?i)\\b429\\s+too many\\b",
        "(?i)\\bhttp\\s*429\\b",
        "(?i)(?:git\\s+)?(?:push|pull|fetch|clone)\\s+[^\\n]{0,200}\\bfatal:\\b",
        "(?i)\\bfatal:\\s*",
        "(?i)\\btraceback\\b",
        "(?i)\\buncaught\\s+exception\\b",
        "(?i)\\bexception:\\s+",
        "(?i)(?:command|operation|request|build|test|npm|yarn|pnpm|cargo)\\s+[^\\n]{0,160}\\bfailed\\b",
        "(?i)\\bfailed\\s+to\\s+(?:connect|resolve|open|read|write|access|authenticate|parse)\\b",
        "(?i)\\bfailed\\s+with\\s+(?:status|code|error)\\b",
        "(?i)\"error\"\\s*:\\s*\\{",
        "(?i)(?:推送|拉取|克隆|上传|下载|连接|编译|构建|安装|操作)(?:已|均)?失败",
        "(?i)(?:命令|脚本|任务|请求|进程)(?:执行|运行)?(?:已|均)?失败",
        "(?i)(?:命令|请求|操作|进程)(?:已)?(?:异常终止|退出码)",
        "(?i)未能\\s*(?:完成|连接|推送|拉取|克隆)",
        "(?i)连接\\s*(?:失败|超时|被拒绝)",
        "(?i)(?:系统|程序)?(?:报错|出错)[：:.．]",
        "(?i)发生(?:了)?(?:严重)?错误[：:.．]"
      ]
    },
    "waitingInput": {
      "titleContains": [],
      "titleRegex": [],
      "tailContains": [
        "would you like to run the following command?",
        "how would you like codex to handle requests",
        "which mode should codex use",
        "press enter to confirm or esc to cancel",
        "yes, proceed (y)",
        "don't ask again",
        "approval required",
        "awaiting approval",
        "allow this action",
        "sandbox_permissions",
        "require_escalated",
        "do you want to allow",
        "read only",
        "full access",
        "[y/n]",
        "(y/n)",
        "请确认",
        "是否允许"
      ],
      "tailRegex": [
        "(?im)^\\s*would you like to run the following command\\?",
        "(?im)^\\s*press enter to confirm or esc to cancel\\b",
        "(?im)^\\s*reason:\\s+"
      ]
    },
    "running": {
      "titleContains": [],
      "titleRegex": [],
      "tailContains": [
        "• working",
        "reconnecting",
        "esc to interrupt",
        "exec_command",
        "apply_patch",
        "update_plan",
        "wait_agent",
        "tool call",
        "compiling",
        "building for debugging",
        "running tests",
        "执行命令",
        "应用补丁"
      ],
      "tailRegex": [
        "(?i)•\\s+working\\b",
        "(?i)(?:•\\s*)?reconnecting\\b",
        "(?im)^\\s*gpt-[0-9.]+-codex\\s+.*left\\s+·"
      ]
    },
    "success": {
      "titleContains": [],
      "titleRegex": [],
      "tailContains": [
        "已按你这次要求完成",
        "验证",
        "swift build 通过",
        "tests passed",
        "patch applied",
        "implemented",
        "completed as requested",
        "all requested changes are complete"
      ],
      "tailRegex": [
        "(?im)^\\s*已按你这次要求完成",
        "(?im)^\\s*验证\\s*$",
        "(?im)^\\s*-\\s*swift build 通过"
      ]
    }
  },
  "defaultLifecycle": "idle",
  "emptyOutput": {
    "lifecycle": "idle",
    "renderTone": "neutral",
    "secondaryText": "当前未运行任务"
  },
  "extraction": {
    "fallbackText": "暂无可展示输出",
    "fallbackMaxLength": 120,
    "byLifecycle": {
      "idle": { "mode": "truncateCompact", "maxLength": 120 },
      "running": { "mode": "truncateCompact", "maxLength": 140 },
      "waitingInput": { "mode": "truncateCompact", "maxLength": 160 },
      "success": { "mode": "truncateCompact", "maxLength": 120 },
      "error": { "mode": "promptAndError" }
    }
  }
}
