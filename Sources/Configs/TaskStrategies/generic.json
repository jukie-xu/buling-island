{
  "strategyID": "generic",
  "displayName": "Shell",
  "priority": 10,
  "supports": {
    "titleContains": [],
    "titleRegex": [],
    "tailContains": [],
    "tailRegex": [".*"]
  },
  "lifecycleRules": {
    "error": {
      "titleContains": [],
      "titleRegex": [],
      "tailContains": [
        "auth_error",
        "unauthorized",
        "401",
        "timeout",
        "timed out",
        "超时"
      ],
      "tailRegex": [
        "(?im)^\\s*error:\\s+",
        "(?i)\"error\"\\s*:\\s*\\{",
        "(?i)\\btraceback\\b",
        "(?i)\\buncaught\\s+exception\\b",
        "(?i)\\bexception:\\s+",
        "(?i)(?:command|operation|request|build|test)\\s+[^\\n]{0,160}\\bfailed\\b",
        "(?i)\\bfailed\\s+to\\s+(?:connect|resolve|open|read|write|access|authenticate|parse)\\b",
        "(?i)\\bfailed\\s+with\\s+(?:status|code|error)\\b",
        "(?i)(?:推送|拉取|克隆|上传|下载|连接|编译|构建|安装|操作)(?:已|均)?失败",
        "(?i)(?:命令|脚本|任务|请求|进程)(?:执行|运行)?(?:已|均)?失败",
        "(?i)(?:系统|程序)?(?:报错|出错)[：:.．]",
        "(?i)发生(?:了)?(?:严重)?错误[：:.．]"
      ]
    },
    "waitingInput": {
      "titleContains": [],
      "titleRegex": [],
      "tailContains": [
        "allow",
        "approve",
        "confirm",
        "[y/n]",
        "(y/n)",
        "请确认",
        "请选择",
        "是否允许"
      ],
      "tailRegex": []
    },
    "running": {
      "titleContains": [],
      "titleRegex": [],
      "tailContains": [
        "running",
        "executing",
        "processing",
        "thinking",
        "analyzing",
        "处理中",
        "执行中",
        "思考中"
      ],
      "tailRegex": []
    },
    "success": {
      "titleContains": [],
      "titleRegex": [],
      "tailContains": [
        "done",
        "completed",
        "finished",
        "success",
        "已完成",
        "成功",
        "完成"
      ],
      "tailRegex": []
    }
  },
  "defaultLifecycle": "idle",
  "emptyOutput": {
    "lifecycle": "inactiveTool",
    "renderTone": "inactive",
    "secondaryText": "当前会话未匹配 Claude/Codex 策略"
  },
  "extraction": {
    "fallbackText": "暂无可展示输出",
    "fallbackMaxLength": 88,
    "byLifecycle": {
      "idle": { "mode": "truncateCompact", "maxLength": 88 },
      "running": { "mode": "promptAndReply" },
      "waitingInput": { "mode": "promptAndReply" },
      "success": { "mode": "promptAndReply" },
      "error": { "mode": "promptAndError" }
    }
  }
}
